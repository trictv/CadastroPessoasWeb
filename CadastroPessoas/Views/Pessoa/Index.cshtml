@{
    ViewBag.Title = "Cadastro de Pessoas";
}

<h2>Cadastro de Pessoas</h2>

<div class="panel panel-default">
    <div class="panel-heading">Dados da Pessoa</div>
    <div class="panel-body">
        <form data-bind="submit: salvar">
            <div class="row">
                <div class="col-md-4 form-group">
                    <label>Nome *</label>
                    <input type="text" class="form-control" data-bind="value: Nome" required maxlength="100" />
                </div>
                <div class="col-md-4 form-group">
                    <label>E-mail *</label>
                    <input type="email" class="form-control" data-bind="value: Email" required maxlength="150" />
                </div>
                <div class="col-md-4 form-group">
                    <label>Data de Nascimento *</label>
                    <input type="date" class="form-control" data-bind="value: DataNascimento" required />
                </div>
            </div>

            <hr />
            <h4>Endereço</h4>
            <div class="row">
                <div class="col-md-3 form-group">
                    <label>CEP *</label>
                    <input type="text" id="Cep" class="form-control" data-bind="value: Cep, valueUpdate: 'afterkeydown'" required />
                </div>
                <div class="col-md-7 form-group">
                    <label>Logradouro *</label>
                    <input type="text" class="form-control" data-bind="value: Logradouro" required maxlength="150" />
                </div>
                <div class="col-md-2 form-group">
                    <label>Número *</label>
                    <input type="text" id="Numero" class="form-control" data-bind="value: Numero" required maxlength="20" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 form-group">
                    <label>Complemento</label>
                    <input type="text" class="form-control" data-bind="value: Complemento" maxlength="100" />
                </div>
                <div class="col-md-3 form-group">
                    <label>Bairro *</label>
                    <input type="text" class="form-control" data-bind="value: Bairro" required maxlength="100" />
                </div>
                <div class="col-md-4 form-group">
                    <label>Cidade *</label>
                    <input type="text" class="form-control" data-bind="value: Cidade" required maxlength="100" />
                </div>
                <div class="col-md-1 form-group">
                    <label>UF *</label>
                    <input type="text" class="form-control" data-bind="value: Uf" required maxlength="2" />
                </div>
            </div>

            <button type="submit" class="btn btn-success">Salvar</button>
            <button type="button" class="btn btn-default" data-bind="click: limparFormulario">Cancelar</button>
        </form>
    </div>
</div>

<hr />

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Nome</th>
            <th>E-mail</th>
            <th>Nascimento</th>
            <th>Cidade/UF</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody data-bind="foreach: pessoas">
        <tr>
            <td data-bind="text: Nome"></td>
            <td data-bind="text: Email"></td>
            <td data-bind="text: new Date(DataNascimento).toLocaleDateString('pt-BR')"></td>
            <td>
                <span data-bind="if: Endereco">
                    <span data-bind="text: Endereco.Cidade"></span>/<span data-bind="text: Endereco.Uf"></span>
                </span>
            </td>
            <td>
                <button class="btn btn-primary btn-sm" data-bind="click: $parent.editar">Editar</button>
                <button class="btn btn-danger btn-sm" data-bind="click: $parent.excluir">Excluir</button>
            </td>
        </tr>
    </tbody>
</table>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/knockout/3.5.1/knockout-latest.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>

    <script>
        function PessoaViewModel() {
            var self = this;

            self.Id = ko.observable(0);
            self.Nome = ko.observable('');
            self.Email = ko.observable('');
            self.DataNascimento = ko.observable('');

            self.EnderecoId = ko.observable(0);
            self.Cep = ko.observable('');
            self.Logradouro = ko.observable('');
            self.Numero = ko.observable('');
            self.Complemento = ko.observable('');
            self.Bairro = ko.observable('');
            self.Cidade = ko.observable('');
            self.Uf = ko.observable('');

            self.pessoas = ko.observableArray([]);

            self.Cep.subscribe(function (novoCep) {
                if (!novoCep) return;

                var cepLimpo = novoCep.replace(/\D/g, '');

                if (cepLimpo.length === 8) {
                    $.getJSON('https://viacep.com.br/ws/' + cepLimpo + '/json/', function (dados) {
                        if (!("erro" in dados)) {
                            self.Logradouro(dados.logradouro);
                            self.Bairro(dados.bairro);
                            self.Cidade(dados.localidade);
                            self.Uf(dados.uf);
                            $('#Numero').focus();
                        } else {
                            alert("CEP não encontrado.");
                        }
                    });
                }
            });

            self.listar = function () {
                $.get('/Pessoa/Listar', function (dados) {
                    var pessoasFormatadas = dados.map(function (p) {
                        if (p.DataNascimento) {
                            var dateMsec = parseInt(p.DataNascimento.replace(/[^0-9]/g, ""));
                            var d = new Date(dateMsec);
                            p.DataNascimento = d.toISOString().split('T')[0];
                        }
                        return p;
                    });
                    self.pessoas(pessoasFormatadas);
                });
            };

            self.salvar = function () {
                var pessoaData = {
                    Id: self.Id(),
                    Nome: self.Nome(),
                    Email: self.Email(),
                    DataNascimento: self.DataNascimento(),
                    Endereco: {
                        Id: self.EnderecoId(),
                        Cep: self.Cep(),
                        Logradouro: self.Logradouro(),
                        Numero: self.Numero(),
                        Complemento: self.Complemento(),
                        Bairro: self.Bairro(),
                        Cidade: self.Cidade(),
                        Uf: self.Uf()
                    }
                };

                $.post('/Pessoa/Salvar', pessoaData, function (resposta) {
                    if (resposta.sucesso) {
                        alert(resposta.mensagem);
                        self.limparFormulario();
                        self.listar();
                    } else {
                        alert("Atenção: " + resposta.mensagem);
                    }
                });
            };

            self.editar = function (pessoa) {
                self.Id(pessoa.Id);
                self.Nome(pessoa.Nome);
                self.Email(pessoa.Email);
                self.DataNascimento(pessoa.DataNascimento);

                if (pessoa.Endereco) {
                    self.EnderecoId(pessoa.Endereco.Id || 0);
                    self.Cep(pessoa.Endereco.Cep);
                    self.Logradouro(pessoa.Endereco.Logradouro);
                    self.Numero(pessoa.Endereco.Numero);
                    self.Complemento(pessoa.Endereco.Complemento);
                    self.Bairro(pessoa.Endereco.Bairro);
                    self.Cidade(pessoa.Endereco.Cidade);
                    self.Uf(pessoa.Endereco.Uf);
                } else {
                    self.EnderecoId(0);
                    self.Cep('');
                    self.Logradouro('');
                    self.Numero('');
                    self.Complemento('');
                    self.Bairro('');
                    self.Cidade('');
                    self.Uf('');
                }
            };

            self.excluir = function (pessoa) {
                if (confirm('Tem certeza que deseja excluir ' + pessoa.Nome + '?')) {
                    $.post('/Pessoa/Excluir', { id: pessoa.Id }, function (resposta) {
                        if (resposta.sucesso) {
                            self.listar();
                        } else {
                            alert(resposta.mensagem);
                        }
                    });
                }
            };

            self.limparFormulario = function () {
                self.Id(0);
                self.Nome('');
                self.Email('');
                self.DataNascimento('');

                self.EnderecoId(0);
                self.Cep('');
                self.Logradouro('');
                self.Numero('');
                self.Complemento('');
                self.Bairro('');
                self.Cidade('');
                self.Uf('');
            };

            self.listar();
        }

        $(document).ready(function () {
            $('#Cep').mask('00000-000');

            ko.applyBindings(new PessoaViewModel());
        });
    </script>
}